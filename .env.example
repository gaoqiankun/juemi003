CUBIFY_IMAGE=cubify3d/cubify3d:latest
CUBIFY_DATA_DIR=/opt/cubify3d/data
CUBIFY_MODEL_DIR=/opt/cubify3d/models/trellis2
CUBIFY_MINIO_DIR=/opt/cubify3d/.minio
ADMIN_TOKEN=
HF_TOKEN=
PROVIDER_MODE=real
MODEL_PATH=microsoft/TRELLIS.2-4B
ARTIFACT_STORE_MODE=local
ALLOWED_CALLBACK_DOMAINS=[]
RATE_LIMIT_CONCURRENT=5
RATE_LIMIT_PER_HOUR=100
DOCKER_RUNTIME=nvidia
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
